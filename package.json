{
  "name": "how-to-madrid",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "build:analyze": "npm run build && npm run bundle-analyzer",
    "bundle-analyzer": "du -sh dist/ && find dist/ -name '*.js' -o -name '*.css' | head -10 | xargs ls -lh",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:run": "vitest run",
    "biome:format": "npx @biomejs/biome format --write",
    "biome:lint": "npx @biomejs/biome lint",
    "biome:check": "npx @biomejs/biome check --write",
    "biome:check:unsafe": "npx @biomejs/biome check --write --unsafe",
    "biome:ci": "npx @biomejs/biome ci ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.41.3",
    "@zachleat/snow-fall": "^1.0.3",
    "astro": "^7.0.9",
    "astro-compress": "^2.4.1",
    "astro-og-canvas": "^0.13.0",
    "sharp": "^0.34.5",
    "starlight-links-validator": "^0.24.0",
    "typescript": "^6.0.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@vitest/ui": "^4.1.8",
    "vitest": "^4.0.3"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "sharp@0.34.5": true,
    "fsevents@2.3.3": true
  }
}
